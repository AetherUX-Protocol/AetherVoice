# --- AetherVoice API Configuration ---

# Vapi API Key: Used for voice orchestration and call handling [cite: 58]
VAPI_API_KEY=your_vapi_private_key_here

# ElevenLabs API Key: Powers the human-like vocal nuance [cite: 58]
ELEVENLABS_API_KEY=your_elevenlabs_key_here

# Gemini or OpenAI API Key: Powers the adaptive interrogation reasoning [cite: 57]
REASONING_ENGINE_API_KEY=your_llm_key_here

# --- Blockchain Configuration (BNB Chain) ---

# Private Key for the Agent's wallet: Used for on-chain settlement [cite: 65]
BNB_PRIVATE_KEY=your_wallet_private_key_here

# RPC URL for BNB Chain (Mainnet or Testnet) [cite: 64]
BNB_RPC_URL=https://bsc-dataseed.binance.org/

# --- Database & RAG Configuration ---

# URL for your vector database or RAG source [cite: 60]
RAG_DATA_SOURCE_URL=your_database_connection_string

# --- Server Configuration ---

# Port for the Node.js webhook handler 
PORT=3000
